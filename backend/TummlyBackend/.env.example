# Copy these into Railway → TummlyBackend service → Variables
# Railway uses double-underscore nesting for .NET configuration keys.
#
# Prerequisite: deploy backend/TummlyDb as a second Railway service first.

ASPNETCORE_ENVIRONMENT=Production

# Reference the SQL Server service (rename TummlyDb if your service uses a different name)
ConnectionStrings__DefaultConnection=Server=${{TummlyDb.RAILWAY_PRIVATE_DOMAIN}},1433;Database=TummlyDB;User Id=sa;Password=${{TummlyDb.MSSQL_SA_PASSWORD}};TrustServerCertificate=True;Encrypt=False;

# Run EF migrations on each deploy (recommended for QA)
Database__ApplyMigrationsOnStartup=true

# Frontend QA URL (Netlify or other)
Frontend__BaseUrl=https://tummly.vercel.app

# Use indexed keys for multiple origins
Cors__AllowedOrigins__0=https://your-qa-site.netlify.app
Cors__AllowedOrigins__1=http://localhost:5173

JwtSettings__Secret=replace-with-a-long-random-secret
JwtSettings__Issuer=TummlyAPI
JwtSettings__Audience=TummlyClient
JwtSettings__ExpiryMinutes=60

EmailSettings__SmtpServer=smtp.gmail.com
EmailSettings__Port=587
EmailSettings__SenderName=Tummly
EmailSettings__SenderEmail=your-email@gmail.com
EmailSettings__Username=your-email@gmail.com
EmailSettings__Password=your-gmail-app-password
