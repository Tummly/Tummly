# Copy these into Railway → TummlyBackend service → Variables
# Railway uses double-underscore nesting for .NET configuration keys.
#
# Database: SQL Server on DigitalOcean VPS (see backend/TummlyDb/vps/)

ASPNETCORE_ENVIRONMENT=Production

# Replace YOUR_VPS_IP and password with values from the VPS .env file
ConnectionStrings__DefaultConnection=Server=YOUR_VPS_IP,1433;Database=TummlyDB;User Id=sa;Password=YOUR_SA_PASSWORD;TrustServerCertificate=True;Encrypt=False;

# Run EF migrations on each deploy (recommended for QA)
Database__ApplyMigrationsOnStartup=true

# Frontend QA URL
Frontend__BaseUrl=https://tummly.vercel.app

Cors__AllowedOrigins__0=https://tummly.vercel.app
Cors__AllowedOrigins__1=http://localhost:5173

JwtSettings__Secret=replace-with-a-long-random-secret
JwtSettings__Issuer=TummlyAPI
JwtSettings__Audience=TummlyClient
JwtSettings__ExpiryMinutes=60

# Resend (HTTPS — works on Railway Hobby, no Pro plan needed)
# Sign up at https://resend.com → API Keys
# QA: use onboarding@resend.dev as sender (can only deliver to your Resend account email until tummly.com is verified)
EmailSettings__ApiKey=re_your_api_key
EmailSettings__SenderName=Tummly
EmailSettings__SenderEmail=onboarding@resend.dev
EmailSettings__ReplyToEmail=engineering@tummly.com
# Until tummly.com is verified on Resend, redirect all sends to your Resend account inbox
EmailSettings__QaRedirectTo=engineering@tummly.com

# Optional: local dev SMTP fallback when ApiKey is not set (Gmail, Freeola, etc.)
