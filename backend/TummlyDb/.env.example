# Railway → TummlyDb service → Variables

MSSQL_SA_PASSWORD=!23Tummly.uk
RAILWAY_RUN_UID=0
MSSQL_MEMORY_LIMIT_MB=384

# If the container keeps restarting on 1 GB free tier:
# 1. DELETE the volume and redeploy (corrupt partial DB files cause silent crashes)
# 2. Or detach the volume entirely to test without persistence
# 3. Or upgrade this service to 2 GB RAM (most reliable for SQL Server)

# Volume mount path: /var/opt/mssql
