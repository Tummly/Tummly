# Frontend API base URL (Dev + QA both use Railway by default)
VITE_API_BASE_URL=https://tummly-backend-production.up.railway.app/api

# Optional: override for local backend only (create .env.development.local)
# VITE_API_BASE_URL=http://localhost:5204/api

# Vercel: set the same variable under Project → Settings → Environment Variables
# for Production and Preview, then redeploy.
